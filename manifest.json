{
  "manifest_version": 3,
  "name": "Mini Translate",
  "version": "1.0.0",
  "description": "极简翻译插件：划词翻译 + Command键段落沉浸翻译（Gemini驱动）",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Mini Translate 设置"
  }
}
